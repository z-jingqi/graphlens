{
  "name": "graphlens",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "package": "npm run build && cd dist && zip -r ../graphlens.zip . -x '*.DS_Store' && cd .. && echo 'Created graphlens.zip'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "npm run build && playwright test",
    "test-app": "node test-app/server.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/prismjs": "^1.26.6",
    "clsx": "^2.1.0",
    "graphql": "^16",
    "prismjs": "^1.30.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-virtuoso": "^4.7.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.8",
    "graphql-sse": "^2.6.0",
    "graphql-ws": "^6.0.8",
    "happy-dom": "^20.10.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^4.1.8",
    "ws": "^8.21.0"
  }
}
